# Secretos — nunca commitear
.env
.streamlit/secrets.toml

# Caches grandes (se regeneran automaticamente desde EDGAR/internet)
data/edgar_facts_cache.json
data/edgar_ciks.json

# Caches efimeros (se regeneran al usar el browser)
data/screener_cache*.json
data/automation_status.json
data/etf_cache.json

# macOS / Python
.DS_Store
__pycache__/
*.py[cod]
*.pyo
.claude/

